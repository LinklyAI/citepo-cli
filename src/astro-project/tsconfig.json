{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@theme/*": ["../theme/clean/*"],
      "@ui/*": ["../ui/*"],
      "@mdx/*": ["../mdx-components/*"]
    }
  },
  "include": ["src", "../theme", "../ui", "../mdx-components"]
}
