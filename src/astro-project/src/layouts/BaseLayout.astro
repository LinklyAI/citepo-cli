---
import '@theme/styles/global.css'
import '@user-style'
import blogConfig from 'virtual:blog-config'
import { buildLayoutMeta } from '../lib/layout-meta.ts'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  type?: 'website' | 'article'
  publishedTime?: string
  authors?: string[]
  tags?: string[]
  lang?: string
  alternateLanguages?: Record<string, string>
}

const {
  title = blogConfig.name,
  description = blogConfig.description,
  ogImage = blogConfig.seo?.ogImage,
  type = 'website',
  publishedTime,
  authors = [],
  tags = [],
  lang = blogConfig.defaultLanguage,
  alternateLanguages = {},
} = Astro.props

const siteUrl = blogConfig.siteUrl
const meta = buildLayoutMeta({
  config: blogConfig,
  siteUrl,
  pathname: Astro.url.pathname,
  title,
  description,
  ogImage,
  type,
  publishedTime,
  authors,
  tags,
  lang,
  alternateLanguages,
})
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{meta.pageTitle}</title>
    {description && <meta name="description" content={description} />}
    {blogConfig.seo?.keywords && (
      <meta name="keywords" content={blogConfig.seo.keywords.join(', ')} />
    )}

    {/* Open Graph */}
    {meta.resolvedOgImage && <meta property="og:image" content={meta.resolvedOgImage} />}
    <meta property="og:title" content={meta.pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    {meta.canonicalUrl && <meta property="og:url" content={meta.canonicalUrl} />}
    <meta property="og:locale" content={lang} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.pageTitle} />
    {description && <meta name="twitter:description" content={description} />}

    {/* Canonical URL */}
    {meta.canonicalUrl && <link rel="canonical" href={meta.canonicalUrl} />}

    {/* Alternate language links (SEO) */}
    {meta.multiLang && Object.entries(meta.resolvedAlternateLanguages).map(([altLang, altUrl]) => (
      <link
        rel="alternate"
        hreflang={altLang}
        href={siteUrl ? `${siteUrl}${altUrl}` : altUrl}
      />
    ))}
    {meta.multiLang && siteUrl && Object.keys(meta.resolvedAlternateLanguages).length > 0 && (
      <link
        rel="alternate"
        hreflang="x-default"
        href={`${siteUrl}${meta.resolvedAlternateLanguages[blogConfig.defaultLanguage] || '/'}`}
      />
    )}

    {/* RSS discovery */}
    {meta.rssUrl && (
      <link rel="alternate" type="application/rss+xml" title={blogConfig.name} href={meta.rssUrl} />
    )}

    <link rel="icon" type="image/svg+xml" href={`${blogConfig.basePath === '/' ? '' : blogConfig.basePath}/favicon.svg`} />

    {/* JSON-LD structured data */}
    <script type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />

    {/* Color overrides from blog.json */}
    {meta.colorOverrides && <style set:html={meta.colorOverrides} />}

    {/* Dark mode init — prevent flash of unstyled content (FOUC) */}
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem('theme')
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
        window.__toggleTheme = function () {
          var html = document.documentElement
          var isDark = html.classList.toggle('dark')
          localStorage.setItem('theme', isDark ? 'dark' : 'light')
        }
      })()
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
