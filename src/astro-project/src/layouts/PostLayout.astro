---
import BaseLayout from './BaseLayout.astro'
import PostPage from '@theme/pages/Post'
import blogConfig from 'virtual:blog-config'
import { isMultiLang } from '../lib/i18n.ts'
import { buildPostPageProps } from '../lib/theme-props.ts'

interface Heading {
  depth: number
  slug: string
  text: string
}

interface PostLink {
  title: string
  url: string
}

interface Props {
  title: string
  description: string
  date: Date
  tags: string[]
  authors: string[]
  coverImage?: string
  headings?: Heading[]
  lang?: string
  translations?: Record<string, string>
  prevPost?: PostLink
  nextPost?: PostLink
}

const {
  title,
  description,
  date,
  tags,
  authors,
  coverImage,
  headings = [],
  lang = blogConfig.defaultLanguage,
  translations = {},
  prevPost,
  nextPost,
} = Astro.props

const multiLang = isMultiLang(blogConfig)
const contextualOptions = blogConfig.contextual?.options

const postPayload = {
  title,
  description,
  date: date.toISOString(),
  dateISO: date.toISOString(),
  tags,
  authors,
  coverImage,
  headings,
}

const postProps = buildPostPageProps({
  config: blogConfig,
  lang,
  translations,
  post: postPayload,
  navigation: {
    prev: prevPost,
    next: nextPost,
  },
  contextualOptions,
})
---

<BaseLayout
  title={title}
  description={description}
  ogImage={coverImage}
  type="article"
  publishedTime={date.toISOString()}
  authors={authors}
  tags={tags}
  lang={lang}
  alternateLanguages={multiLang ? translations : undefined}
>
  <PostPage
    client:load
    {...postProps}
  >
    <slot />
  </PostPage>
</BaseLayout>
