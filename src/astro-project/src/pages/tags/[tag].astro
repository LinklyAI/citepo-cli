---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import ListPage from '@theme/pages/List'
import blogConfig from 'virtual:blog-config'
import {
  buildAlternateLanguagesForTag,
  filterPostsByLang,
  getLangHomeUrl,
  isMultiLang,
} from '../../lib/i18n.ts'
import { buildListPageProps, mapPostEntryToSummary } from '../../lib/theme-props.ts'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const langPosts = isMultiLang(blogConfig)
    ? filterPostsByLang(allPosts, blogConfig.defaultLanguage, blogConfig)
    : allPosts

  const tagSet = new Set<string>()
  for (const post of langPosts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag)
    }
  }

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: langPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }))
}

const { tag, posts } = Astro.props
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const lang = blogConfig.defaultLanguage
const homeUrl = getLangHomeUrl(lang, blogConfig)
const translations = isMultiLang(blogConfig)
  ? buildAlternateLanguagesForTag(tag, allPosts, blogConfig)
  : {}
const pageProps = buildListPageProps({
  config: blogConfig,
  lang,
  translations,
  title: `#${tag}`,
  description: `${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`,
  items: posts.map((post) => mapPostEntryToSummary(post, blogConfig)),
  backLink: {
    href: homeUrl,
    label: 'All posts',
  },
})
---

<BaseLayout
  lang={lang}
  title={`#${tag}`}
  description={`Posts tagged with "${tag}"`}
  alternateLanguages={translations}
>
  <ListPage client:load {...pageProps} />
</BaseLayout>
