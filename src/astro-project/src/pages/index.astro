---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import HomePage from '@theme/pages/Home'
import blogConfig from 'virtual:blog-config'
import {
  buildAlternateLanguagesForPath,
  filterPostsByLang,
  isMultiLang,
} from '../lib/i18n.ts'
import { paginatePosts } from '../lib/pagination.ts'
import { buildIndexPageProps, mapPostEntryToSummary } from '../lib/theme-props.ts'

// Root always renders default language content (no redirect)
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const lang = blogConfig.defaultLanguage
const langPosts = isMultiLang(blogConfig)
  ? filterPostsByLang(allPosts, lang, blogConfig)
  : allPosts
const sortedPosts = langPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const { items, totalPages, currentPage } = paginatePosts(sortedPosts, 1, blogConfig.postsPerPage)
const translations = isMultiLang(blogConfig)
  ? buildAlternateLanguagesForPath(Astro.url.pathname, blogConfig)
  : {}
const pageProps = buildIndexPageProps({
  config: blogConfig,
  lang,
  translations,
  posts: items.map((post) => mapPostEntryToSummary(post, blogConfig)),
  pagination: { currentPage, totalPages },
})
---

<BaseLayout lang={lang} alternateLanguages={translations}>
  <HomePage client:load {...pageProps} />
</BaseLayout>
