---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '@theme/components/PostCard.tsx'
import Pagination from '@theme/components/Pagination.tsx'
import HeroBanner from '@theme/components/HeroBanner.tsx'
import blogConfig from 'virtual:blog-config'
import { isMultiLang, getPostUrl, getLangHomeUrl, getPaginationBaseUrl } from '../../lib/i18n.ts'
import { paginatePosts, generatePaginationPaths } from '../../lib/pagination.ts'

export async function getStaticPaths() {
  // Multi-lang: pagination is under /[lang]/page/[page]
  if (isMultiLang(blogConfig)) return []

  // Single-lang: generate page 2+ at root level
  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const pages = generatePaginationPaths(allPosts.length, blogConfig.postsPerPage)

  return pages.map((page) => ({
    params: { page: String(page) },
    props: { page },
  }))
}

const { page } = Astro.props
const lang = blogConfig.defaultLanguage
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const { items, totalPages, currentPage } = paginatePosts(sortedPosts, page, blogConfig.postsPerPage)
const homeUrl = getLangHomeUrl(lang, blogConfig)
const paginationBase = getPaginationBaseUrl(lang, blogConfig)
---

<BaseLayout lang={lang} title={`Page ${currentPage} - ${blogConfig.name}`}>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <HeroBanner image={blogConfig.hero?.image} alt={blogConfig.name} />

    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold tracking-tight text-foreground mb-3">
        {blogConfig.name}
      </h1>
      {blogConfig.description && (
        <p class="text-muted-foreground text-lg">
          {blogConfig.description}
        </p>
      )}
    </div>

    <div class="flex flex-col gap-2">
      {items.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date.toISOString()}
          tags={post.data.tags}
          slug={post.id}
          coverImage={post.data.coverImage || undefined}
          url={getPostUrl(post.id, blogConfig)}
        />
      ))}
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      homeUrl={homeUrl}
      paginationBase={paginationBase}
    />
  </div>
</BaseLayout>
