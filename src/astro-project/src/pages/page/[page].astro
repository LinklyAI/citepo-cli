---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import HomePage from '@theme/pages/Home'
import blogConfig from 'virtual:blog-config'
import {
  buildAlternateLanguagesForPagination,
  filterPostsByLang,
  isMultiLang,
} from '../../lib/i18n.ts'
import { paginatePosts, generatePaginationPaths } from '../../lib/pagination.ts'
import { buildIndexPageProps, mapPostEntryToSummary } from '../../lib/theme-props.ts'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const langPosts = isMultiLang(blogConfig)
    ? filterPostsByLang(allPosts, blogConfig.defaultLanguage, blogConfig)
    : allPosts
  const pages = generatePaginationPaths(langPosts.length, blogConfig.postsPerPage)

  return pages.map((page) => ({
    params: { page: String(page) },
    props: { page },
  }))
}

const { page } = Astro.props
const lang = blogConfig.defaultLanguage
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const langPosts = isMultiLang(blogConfig)
  ? filterPostsByLang(allPosts, lang, blogConfig)
  : allPosts
const sortedPosts = langPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const { items, totalPages, currentPage } = paginatePosts(sortedPosts, page, blogConfig.postsPerPage)
const translations = isMultiLang(blogConfig)
  ? buildAlternateLanguagesForPagination(page, allPosts, blogConfig, blogConfig.postsPerPage)
  : {}
const pageProps = buildIndexPageProps({
  config: blogConfig,
  lang,
  translations,
  posts: items.map((post) => mapPostEntryToSummary(post, blogConfig)),
  pagination: { currentPage, totalPages },
})
---

<BaseLayout
  lang={lang}
  title={`Page ${currentPage} - ${blogConfig.name}`}
  alternateLanguages={translations}
>
  <HomePage client:load {...pageProps} />
</BaseLayout>
