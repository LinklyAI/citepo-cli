---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ListPage from '@theme/pages/List'
import blogConfig from 'virtual:blog-config'
import {
  buildAlternateLanguagesForTag,
  filterPostsByLang,
  getLangHomeUrl,
  getNonDefaultLanguages,
  isMultiLang,
} from '../../../lib/i18n.ts'
import { buildListPageProps, mapPostEntryToSummary } from '../../../lib/theme-props.ts'

export async function getStaticPaths() {
  if (!isMultiLang(blogConfig)) return []

  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const paths: { params: { lang: string; tag: string }; props: { lang: string; tag: string; posts: typeof allPosts } }[] = []

  // Generate for non-default languages only
  for (const lang of getNonDefaultLanguages(blogConfig)) {
    const langPosts = filterPostsByLang(allPosts, lang, blogConfig)
    const tagSet = new Set<string>()
    for (const post of langPosts) {
      for (const tag of post.data.tags) {
        tagSet.add(tag)
      }
    }

    for (const tag of tagSet) {
      paths.push({
        params: { lang, tag },
        props: {
          lang,
          tag,
          posts: langPosts
            .filter((post) => post.data.tags.includes(tag))
            .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
        },
      })
    }
  }

  return paths
}

const { lang, tag, posts } = Astro.props
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const homeUrl = getLangHomeUrl(lang, blogConfig)
const translations = isMultiLang(blogConfig)
  ? buildAlternateLanguagesForTag(tag, allPosts, blogConfig)
  : {}
const pageProps = buildListPageProps({
  config: blogConfig,
  lang,
  translations,
  title: `#${tag}`,
  description: `${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`,
  items: posts.map((post) => mapPostEntryToSummary(post, blogConfig)),
  backLink: {
    href: homeUrl,
    label: 'All posts',
  },
})
---

<BaseLayout
  lang={lang}
  title={`#${tag}`}
  description={`Posts tagged with "${tag}"`}
  alternateLanguages={translations}
>
  <ListPage client:load {...pageProps} />
</BaseLayout>
