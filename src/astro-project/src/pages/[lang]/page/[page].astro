---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostCard from '@theme/components/PostCard.tsx'
import Pagination from '@theme/components/Pagination.tsx'
import HeroBanner from '@theme/components/HeroBanner.tsx'
import blogConfig from 'virtual:blog-config'
import { isMultiLang, getNonDefaultLanguages, filterPostsByLang, getPostUrl, getLangHomeUrl, getPaginationBaseUrl, buildAlternateLanguagesForPagination } from '../../../lib/i18n.ts'
import { paginatePosts, generatePaginationPaths } from '../../../lib/pagination.ts'

export async function getStaticPaths() {
  if (!isMultiLang(blogConfig)) return []

  const allPosts = await getCollection('blog', ({ data }) => !data.draft)
  const paths: { params: { lang: string; page: string }; props: { lang: string; page: number } }[] = []

  // Generate for non-default languages only
  for (const lang of getNonDefaultLanguages(blogConfig)) {
    const langPosts = filterPostsByLang(allPosts, lang, blogConfig)
    const pages = generatePaginationPaths(langPosts.length, blogConfig.postsPerPage)

    for (const page of pages) {
      paths.push({
        params: { lang, page: String(page) },
        props: { lang, page },
      })
    }
  }

  return paths
}

const { lang, page } = Astro.props
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const langPosts = filterPostsByLang(allPosts, lang, blogConfig)
const sortedPosts = langPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const { items, totalPages, currentPage } = paginatePosts(sortedPosts, page, blogConfig.postsPerPage)
const homeUrl = getLangHomeUrl(lang, blogConfig)
const paginationBase = getPaginationBaseUrl(lang, blogConfig)
const alternateLanguages = isMultiLang(blogConfig)
  ? buildAlternateLanguagesForPagination(page, allPosts, blogConfig, blogConfig.postsPerPage)
  : {}
---

<BaseLayout
  lang={lang}
  title={`Page ${currentPage} - ${blogConfig.name}`}
  alternateLanguages={alternateLanguages}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <HeroBanner image={blogConfig.hero?.image} alt={blogConfig.name} />

    <div class="text-center mb-12">
      <h1 class="page-title mb-3">
        {blogConfig.name}
      </h1>
      {blogConfig.description && (
        <p class="page-description">
          {blogConfig.description}
        </p>
      )}
    </div>

    <div class="flex flex-col gap-2">
      {items.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date.toISOString()}
          tags={post.data.tags}
          slug={post.id}
          coverImage={post.data.coverImage || undefined}
          url={getPostUrl(post.id, blogConfig)}
        />
      ))}
    </div>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      homeUrl={homeUrl}
      paginationBase={paginationBase}
    />
  </div>
</BaseLayout>
