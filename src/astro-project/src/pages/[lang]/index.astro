---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import HomePage from '@theme/pages/Home'
import blogConfig from 'virtual:blog-config'
import {
  buildAlternateLanguagesForPath,
  filterPostsByLang,
  getLangHomeUrl,
  getNonDefaultLanguages,
  isMultiLang,
} from '../../lib/i18n.ts'
import { paginatePosts } from '../../lib/pagination.ts'
import { buildIndexPageProps, mapPostEntryToSummary } from '../../lib/theme-props.ts'

export async function getStaticPaths() {
  if (!isMultiLang(blogConfig)) return []

  // Generate for non-default languages only
  return getNonDefaultLanguages(blogConfig).map((lang) => ({
    params: { lang },
    props: { lang },
  }))
}

const { lang } = Astro.props
const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const langPosts = filterPostsByLang(allPosts, lang, blogConfig)
const sortedPosts = langPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)

const { items, totalPages, currentPage } = paginatePosts(sortedPosts, 1, blogConfig.postsPerPage)
const translations = buildAlternateLanguagesForPath(getLangHomeUrl(lang, blogConfig), blogConfig)
const pageProps = buildIndexPageProps({
  config: blogConfig,
  lang,
  translations,
  posts: items.map((post) => mapPostEntryToSummary(post, blogConfig)),
  pagination: { currentPage, totalPages },
})
---

<BaseLayout lang={lang} alternateLanguages={translations}>
  <HomePage client:load {...pageProps} />
</BaseLayout>
