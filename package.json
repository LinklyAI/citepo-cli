{
  "name": "citepo",
  "version": "0.1.13",
  "description": "A lightweight CLI for creating, previewing, and building blogs",
  "type": "module",
  "bin": {
    "citepo": "dist/cli/index.js",
    "ctp": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "src/astro-project/src/",
    "src/astro-project/tsconfig.json",
    "src/engine/",
    "src/ui/",
    "src/theme/",
    "src/mdx-components/",
    "src/scaffold/"
  ],
  "scripts": {
    "build": "tsup && tsx src/engine/schema-cli.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css,md,mdx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "schema:generate": "tsx src/engine/schema-cli.ts",
    "generate:starter": "tsx scripts/generate-starter.ts",
    "package:runtime": "bash scripts/package-runtime.sh"
  },
  "keywords": [
    "blog",
    "cli",
    "astro",
    "mdx",
    "static-site-generator",
    "ssg"
  ],
  "author": "LinklyAI",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/LinklyAI/citepo-cli.git"
  },
  "homepage": "https://citepo.com",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@clack/prompts": "^0.10.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "sugar-high": "^0.9.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.4.1",
    "vitest": "^3.0.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
